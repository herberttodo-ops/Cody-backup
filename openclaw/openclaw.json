{
  "agents": {
    "defaults": {
      "workspace": "/home/herby/.openclaw/workspace",
      "models": {
        "openrouter/auto": {
          "alias": "OpenRouter"
        },
        "openrouter/moonshotai/kimi-k2.5": {},
        "openrouter/anthropic/claude-opus-4": {},
        "openrouter/anthropic/claude-opus-4.6": {},
        "openrouter/anthropic/claude-sonnet-4.6": {}
      },
      "model": {
        "primary": "openrouter/anthropic/claude-haiku-4.5"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "___TOKEN___"
    },
    "port": 18789,
    "bind": "loopback",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "allowInsecureAuth": true
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "coding",
    "web": {
      "search": {
        "provider": "duckduckgo",
        "enabled": true
      }
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": [
        "___ID_NUMBER___"
      ],
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "botToken": "___BOT_TOKEN___",
      "streaming": "partial",
      "mediaMaxMb": 50
    }
  },
  "plugins": {
    "entries": {
      "duckduckgo": {
        "enabled": true
      }
    }
  },
  "wizard": {
